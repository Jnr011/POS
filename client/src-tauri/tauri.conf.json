{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pharmacy POS",
  "version": "1.2.0",
  "identifier": "com.pharmacy.pos",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/Jnr011/POS/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBNkUzM0RFRjE3OTBBMjAKUldRZ0Nubngzak51eXUzcTg2d2pQTWlEcWoyT2JUKzNkUHpxQlMyR1NlclhnM0dlMmhrTzVqbDIK"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pharmacy POS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:5000; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "sideBySide": false
      }
    },
    "linux": {}
  }
}
